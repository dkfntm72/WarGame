      unitType: 0
      faction: 0
      spawnX: 0
      spawnY: 0
      spawnRank: 0
    - actionType: 0
      speakerName: "\uBD80\uAD00 \uBCA0\uB978\uD558\uB974\uD2B8"
      dialogueLines:
      - "\uC774\uBC88 \uC804\uD22C\uC5D0\uC11C \uCCA0\uBCBD\uC655\uAD6D\uB3C4 \uC9C0\uC6D0\uAD70\uC744
        \uBCF4\uB0B4\uC654\uC2B5\uB2C8\uB2E4"
      - "\uADF8\uB4E4\uC774 \uC6B0\uCE21\uC73C\uB85C \uC9C4\uACA9\uD560 \uAC83\uC785\uB2C8\uB2E4"
      text: "\uC774\uBC88 \uC804\uD22C\uC5D0\uC11C \uCCA0\uBCBD\uC655\uAD6D\uB3C4
