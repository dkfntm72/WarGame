  - id: 2
    conditionType: 4
    x1: 10
    y1: 27
    x2: 10
    y2: 27
    turnNumber: 0
    captureByFaction: 1
    fireOnce: 1
    actions:
    - actionType: 0
      speakerName: "\uCE74\uB97C"
      dialogueLines:
      - "\uB05D\uB0AC\uB2E4 \uBD81\uBC29\uC655\uAD6D\uC758 \uAD70\uB300\uB294 \uAD34\uBA78\uB418\uC5C8\uB2E4"
      text: "\uB05D\uB0AC\uB2E4 \uBD81\uBC29\uC655\uAD6D\uC758 \uAD70\uB300\uB294
        \uAD34\uBA78\uB418\uC5C8\uB2E4"
      unitType: 0
