      spawnX: 0
      spawnY: 0
      spawnRank: 0
    - actionType: 0
      speakerName: "\uBD80\uAD00 \uBCA0\uB978\uD558\uB974\uD2B8"
      dialogueLines:
      - "\uC774\uC81C \uBD81\uBC29\uC655\uAD6D\uC758 \uC218\uB3C4\uB9CC \uB0A8\uC558\uC2B5\uB2C8\uB2E4"
      text: "\uC774\uC81C \uBD81\uBC29\uC655\uAD6D\uC758 \uC218\uB3C4\uB9CC \uB0A8\uC558\uC2B5\uB2C8\uB2E4"
      unitType: 0
      faction: 0
      spawnX: 0
      spawnY: 0
      spawnRank: 0
    - actionType: 0
      speakerName: "\uCE74\uB97C"
      dialogueLines:
      - "\uADF8\uB798 \uBC14\uB85C \uC218\uB3C4\uB85C \uC9C4\uAD70\uD574 \uD3EC\uC704\uD558\uB77C"
