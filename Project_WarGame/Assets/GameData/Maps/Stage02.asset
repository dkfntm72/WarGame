  - id: 2
    conditionType: 4
    x1: 11
    y1: 9
    x2: 11
    y2: 9
    turnNumber: 0
    captureByFaction: 1
    fireOnce: 1
    actions:
    - actionType: 0
      speakerName: "\uCE74\uB97C"
      dialogueLines:
      - "\uC804\uBC29\uC5D0 \uC788\uB294 \uC801\uC758 \uC9C4\uC601\uC740 \uBC29\uBE44\uAC00
        \uCCA0\uC800\uD558\uB2E4 \uBCD1\uB825\uC744 \uCDA9\uBD84\uD788 \uBAA8\uC73C\uACE0
        \uACF5\uACA9\uD574\uC57C\uD55C\uB2E4"
      - "\uC11C\uBD81\uCABD\uC5D0\uC791\uC740 \uC9C4\uC601\uC774 \uC788\uAD70 \uC774\uACF3\uC5D0\uC11C
        \uBB54\uAC00\uB97C \uC5BB\uC744 \uC218 \uC788\uC744 \uC9C0\uB3C4..."
