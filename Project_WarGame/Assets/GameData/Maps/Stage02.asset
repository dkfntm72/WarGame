      unitType: 0
      faction: 0
      spawnX: 0
      spawnY: 0
      spawnRank: 0
    - actionType: 0
      speakerName: "\uBD80\uAD00 \uBCA0\uB978\uD558\uB974\uD2B8"
      dialogueLines:
      - "\uACF5\uACA9\uC744 \uC704\uD55C \uC815\uC608\uC804\uC0AC\uB4E4\uC774 \uB9C8\uCE68
        \uC900\uBE44\uB97C \uB9C8\uCCE4\uC2B5\uB2C8\uB2E4"
      text: "\uACF5\uACA9\uC744 \uC704\uD55C \uC815\uC608\uC804\uC0AC\uB4E4\uC774
        \uB9C8\uCE68 \uC900\uBE44\uB97C \uB9C8\uCCE4\uC2B5\uB2C8\uB2E4"
      unitType: 0
      faction: 0
      spawnX: 0
      spawnY: 0
      spawnRank: 0
    - actionType: 0
      speakerName: "\uCE74\uB97C"
      dialogueLines:
      - "\uC88B\uB2E4 \uC804\uAD70 \uC9C4\uACA9\uD558\uB77C!"
      text: "\uC88B\uB2E4 \uC804\uAD70 \uC9C4\uACA9\uD558\uB77C!"
      unitType: 0
      faction: 0
      spawnX: 0
      spawnY: 0
