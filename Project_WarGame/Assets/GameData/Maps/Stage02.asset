      dialogueLines:
      - "\uC218\uC2DC\uB85C \uC57D\uD0C8\uD558\uB7EC \uC624\uB294 \uBD81\uBC29\uAD6D\uC744
        \uB354\uC774\uC0C1 \uC88C\uC2DC\uD560 \uC218 \uC5C6\uB2E4 \uC774\uBC88 \uAE30\uD68C\uB85C
        \uC57D\uD654\uC2DC\uCF1C\uC57C\uD55C\uB2E4"
      text: "\uC218\uC2DC\uB85C \uC57D\uD0C8\uD558\uB7EC \uC624\uB294 \uBD81\uBC29\uAD6D\uC744
        \uB354\uC774\uC0C1 \uC88C\uC2DC\uD560 \uC218 \uC5C6\uB2E4 \uC774\uBC88 \uAE30\uD68C\uB85C
